{
  "name": "@colbymchenry/codegraph",
  "version": "1.5.0",
  "description": "Supercharge AI coding agents with semantic code intelligence — surgical context, fewer tool calls, faster answers. 100% local.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/colbymchenry/codegraph.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codegraph": "./dist/bin/codegraph.js"
  },
  "workspaces": [
    "web"
  ],
  "files": [
    "dist",
    "actions",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:web && npm run copy-assets && npm run copy-web-assets && npm run build:pr-impact-action && node -e \"require('fs').chmodSync('dist/bin/codegraph.js', 0o755)\"",
    "build:web": "npm --prefix web run build",
    "build:pr-impact-action": "tsc actions/pr-impact/run.ts --target ES2022 --module ES2022 --moduleResolution node --types node --skipLibCheck --outDir actions/pr-impact/dist/.build --declaration false --sourceMap false && node -e \"const fs=require('fs');fs.copyFileSync('actions/pr-impact/dist/.build/run.js','actions/pr-impact/dist/run.mjs');fs.rmSync('actions/pr-impact/dist/.build',{recursive:true,force:true})\"",
    "preuninstall": "node dist/bin/uninstall.js",
    "copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/schema.sql','dist/db/schema.sql');fs.mkdirSync('dist/extraction/wasm',{recursive:true});fs.readdirSync('src/extraction/wasm').filter(f=>f.endsWith('.wasm')).forEach(f=>fs.copyFileSync('src/extraction/wasm/'+f,'dist/extraction/wasm/'+f));fs.mkdirSync('dist/server',{recursive:true});fs.copyFileSync('src/server/openapi.yaml','dist/server/openapi.yaml')\"",
    "copy-web-assets": "node scripts/copy-web-assets.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && npm run typecheck:web",
    "typecheck:web": "npm --prefix web run typecheck",
    "cli": "npm run build && node dist/bin/codegraph.js",
    "test": "vitest run",
    "test:web": "npm --prefix web run test",
    "test:watch": "vitest",
    "test:eval": "vitest run __tests__/evaluation/",
    "eval": "npm run build && npx tsx __tests__/evaluation/runner.ts",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.2",
    "fast-string-width": "^3.0.2",
    "fast-wrap-ansi": "^0.2.0",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "onnxruntime-web": "^1.27.0",
    "picomatch": "^4.0.4",
    "sisteransi": "^1.0.5",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.30",
    "@types/picomatch": "^4.0.2",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  }
}
